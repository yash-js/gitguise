{
  "name": "gitguise",
  "productName": "GitGuise",
  "version": "0.2.1",
  "description": "One machine. Many identities.",
  "author": "Yash Purani <yashpurani@users.noreply.github.com>",
  "homepage": "https://gitguise.dev",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all": "electron-builder -mwl --publish never"
  },
  "build": {
    "appId": "app.gitguise",
    "productName": "GitGuise",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "yash-js",
      "repo": "gitguise"
    },
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "src/assets/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "src/assets/icon.png",
      "category": "Development",
      "maintainer": "Yash Purani <yashpurani@users.noreply.github.com>"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.9.0",
    "node-pty": "^1.0.0"
  }
}
